<meta name="msvalidate.01" content="D1FF13BAA498D20BAEC5F72C01CD9086" /><script>document.addEventListener('DOMContentLoaded', function() {
    
    // --- DICTIONNAIRE LOREM ---
    const words = [
        "lorem", "ipsum", "dolor", "sit", "amet", "consectetur", "adipiscing", "elit", "sed", "do", "eiusmod", 
        "tempor", "incididunt", "ut", "labore", "et", "dolore", "magna", "aliqua", "ut", "enim", "ad", "minim", 
        "veniam", "quis", "nostrud", "exercitation", "ullamco", "laboris", "nisi", "ut", "aliquip", "ex", "ea", 
        "commodo", "consequat", "duis", "aute", "irure", "dolor", "in", "reprehenderit", "in", "voluptate", 
        "velit", "esse", "cillum", "dolore", "eu", "fugiat", "nulla", "pariatur", "excepteur", "sint", "occaecat", 
        "cupidatat", "non", "proident", "sunt", "in", "culpa", "qui", "officia", "deserunt", "mollit", "anim", 
        "id", "est", "laborum"
    ];

    // --- ELEMENTS ---
    const countInput = document.getElementById('lorem-count');
    const typeBtns = document.querySelectorAll('.toggle-btn');
    const formatSelect = document.getElementById('lorem-format');
    const startCheckbox = document.getElementById('start-lorem');
    const generateBtn = document.getElementById('btn-generate');
    const resultArea = document.getElementById('lorem-result');
    const copyBtn = document.getElementById('btn-copy');

    let currentType = 'paragraphs'; // Default

    // --- GESTION DES TYPES (Boutons) ---
    typeBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
            typeBtns.forEach(b => b.classList.remove('active'));
            e.target.classList.add('active');
            currentType = e.target.dataset.type;
        });
    });

    // --- GENERATEUR DE TEXTE ---
    function generateLorem() {
        let count = parseInt(countInput.value) || 5;
        let format = formatSelect.value;
        let startWith = startCheckbox.checked;
        let output = "";
        let rawData = [];

        // 1. Générer les données brutes
        for (let i = 0; i < count; i++) {
            if (currentType === 'words') {
                rawData.push(getWord(i === 0 && startWith));
            } else if (currentType === 'sentences') {
                rawData.push(getSentence(i === 0 && startWith));
            } else { // paragraphs
                rawData.push(getParagraph(i === 0 && startWith));
            }
        }

        // 2. Formater la sortie
        if (format === 'json') {
            output = JSON.stringify(rawData, null, 4);
        } else if (format === 'html') {
            if (currentType === 'paragraphs') {
                output = rawData.map(p => `<p>${p}</p>`).join('\n\n');
            } else if (currentType === 'sentences') {
                output = rawData.map(s => `<li>${s}</li>`).join('\n');
                output = `<ul>\n${output}\n</ul>`;
            } else {
                output = rawData.join(' ');
            }
        } else { // Plain text
            output = rawData.join(currentType === 'words' ? ' ' : '\n\n');
        }

        resultArea.value = output;
    }

    // --- FONCTIONS AUXILIAIRES ---
    function getWord(forceLorem) {
        if (forceLorem) return "Lorem";
        return words[Math.floor(Math.random() * words.length)];
    }

    function getSentence(forceLorem) {
        let length = Math.floor(Math.random() * 10) + 8; // 8-18 mots
        let sentence = [];
        if (forceLorem) {
            sentence.push("Lorem", "ipsum", "dolor", "sit", "amet");
            length -= 5;
        }
        for (let i = 0; i < length; i++) {
            sentence.push(getWord(false));
        }
        let text = sentence.join(' ');
        return text.charAt(0).toUpperCase() + text.slice(1) + ".";
    }

    function getParagraph(forceLorem) {
        let length = Math.floor(Math.random() * 3) + 3; // 3-6 phrases
        let paragraph = [];
        for (let i = 0; i < length; i++) {
            paragraph.push(getSentence(forceLorem && i === 0));
        }
        return paragraph.join(' ');
    }

    // --- COPY TO CLIPBOARD ---
    copyBtn.addEventListener('click', () => {
        resultArea.select();
        document.execCommand('copy');
        
        let originalText = copyBtn.innerText;
        copyBtn.innerText = "✅ Copied!";
        copyBtn.style.background = "#10b981";
        
        setTimeout(() => {
            copyBtn.innerText = originalText;
            copyBtn.style.background = "#334155";
        }, 2000);
    });

    // --- INITIALISATION ---
    generateBtn.addEventListener('click', generateLorem);
    generateLorem(); // Générer au chargement
});</script><script>document.addEventListener('DOMContentLoaded', function() {
    // Lancement initial
    setTimeout(function() {
        safeGenerateRetail();
        safeGenerateQR();
    }, 500); // Petit délai pour être sûr que tout est chargé
});

// --- 1. RETAIL BARCODE (EAN/UPC) ---
function safeGenerateRetail() {
    const container = document.getElementById('retail-container');
    const inputVal = document.getElementById('retail-input').value;
    const type = document.getElementById('retail-type').value;
    const helper = document.getElementById('retail-helper');

    if(!container) return;

    // 1. Nettoyage et Création Dynamique de l'élément Image
    // On utilise <img> au lieu de <svg> car c'est plus robuste sur WP
    container.innerHTML = '<img id="barcode-target" />';
    
    const target = document.getElementById('barcode-target');
    const cleanVal = inputVal.replace(/\D/g,''); // Chiffres uniquement

    try {
        // Validation basique
        let format = (type === 'ean13') ? 'EAN13' : 'UPC';
        
        // Appel de la librairie
        JsBarcode(target, cleanVal, {
            format: format,
            lineColor: "#000",
            width: 2,
            height: 80,
            displayValue: true,
            margin: 10
        });
        
        helper.innerText = "Valid format generated.";
        helper.style.color = "#16a34a"; // Vert
        
    } catch (e) {
        // En cas d'erreur (ex: pas assez de chiffres), on ne casse rien
        // On affiche juste un message discret
        helper.innerText = "Waiting for valid input... (" + cleanVal.length + " digits)";
        helper.style.color = "#94a3b8"; // Gris
        
        // Optionnel : Effacer l'image cassée
        container.innerHTML = '<span style="color:#cbd5e1; font-style:italic;">Barcode will appear here</span>';
    }
}

// --- CONFIGURATION QR ---
const qrOptions = {
    width: 250,
    height: 250,
    type: "svg", // Vectoriel
    dotsOptions: { color: "#0f172a", type: "rounded" },
    backgroundOptions: { color: "#ffffff" }
};

// Initialisation unique des objets QR
// On vérifie si la librairie est chargée avant de créer
let urlQr, wifiQr;
if (typeof QRCodeStyling !== 'undefined') {
    urlQr = new QRCodeStyling(qrOptions);
    wifiQr = new QRCodeStyling(qrOptions);
}

// --- 2. URL QR ---
function safeGenerateQR() {
    if (typeof QRCodeStyling === 'undefined') return; // Sécurité si lib non chargée

    const val = document.getElementById('url-input').value;
    const container = document.getElementById('url-qr-output');
    
    if(!container) return;
    container.innerHTML = ""; // Reset

    if(val.trim() !== "") {
        urlQr.update({ data: val });
        urlQr.append(container);
    } else {
        container.innerHTML = '<span style="color:#cbd5e1;">Enter URL...</span>';
    }
}

// --- 3. WIFI QR ---
function safeGenerateWifi() {
    if (typeof QRCodeStyling === 'undefined') return;

    const ssid = document.getElementById('wifi-ssid').value;
    const pass = document.getElementById('wifi-pass').value;
    const container = document.getElementById('wifi-qr-output');
    
    if(!container) return;
    container.innerHTML = "";

    if(ssid.trim() !== "") {
        // Format WIFI:S:SSID;T:WPA;P:PASSWORD;;
        const wifiData = `WIFI:S:${ssid};T:WPA;P:${pass};;`;
        wifiQr.update({ data: wifiData });
        wifiQr.append(container);
    } else {
        container.innerHTML = '<span style="color:#cbd5e1;">Enter Network Name...</span>';
    }
}</script><script>document.addEventListener('DOMContentLoaded', function() {
    
    // --- 1. FONCTION DE LECTURE ---
    function playChannel(type) {
        // Reset Visuel
        document.querySelectorAll('.act-speaker').forEach(el => el.classList.remove('playing'));
        document.getElementById('act-status').innerText = "PLAYING: " + type.toUpperCase();
        
        // Stop tous les sons
        document.querySelectorAll('audio').forEach(a => { a.pause(); a.currentTime = 0; });

        // Cibler l'audio
        var audioEl = document.getElementById('audio-' + type);
        
        if (!audioEl) return alert("Erreur : Audio introuvable (ID incorrect).");
        if (!audioEl.src) return alert("Erreur : Aucun lien fichier pour cet audio.");

        // Lecture
        var p = audioEl.play();
        if (p !== undefined) {
            p.then(() => {
                // Animation
                if(type === 'left' || type === 'stereo' || type.includes('phase')) 
                    document.getElementById('vis-left').classList.add('playing');
                
                if(type === 'right' || type === 'stereo' || type.includes('phase')) 
                    document.getElementById('vis-right').classList.add('playing');

            }).catch(e => {
                alert("Erreur Lecture : " + e.message + "\nLien: " + audioEl.src);
            });
        }

        // Fin de lecture
        audioEl.onended = function() {
            document.querySelectorAll('.act-speaker').forEach(el => el.classList.remove('playing'));
            document.getElementById('act-status').innerText = "READY";
        };
    }

    // --- 2. ATTACHEMENT DES ÉVÉNEMENTS (C'est la clé !) ---
    // On attache le clic manuellement pour contourner la sécurité HTML de WordPress
    
    var btnLeft = document.getElementById('btn-left');
    if(btnLeft) btnLeft.addEventListener('click', function() { playChannel('left'); });

    var btnRight = document.getElementById('btn-right');
    if(btnRight) btnRight.addEventListener('click', function() { playChannel('right'); });

    var btnStereo = document.getElementById('btn-stereo');
    if(btnStereo) btnStereo.addEventListener('click', function() { playChannel('stereo'); });

    var btnIn = document.getElementById('btn-inphase');
    if(btnIn) btnIn.addEventListener('click', function() { playChannel('inphase'); });

    var btnOut = document.getElementById('btn-outphase');
    if(btnOut) btnOut.addEventListener('click', function() { playChannel('outphase'); });

});</script><script>document.addEventListener('DOMContentLoaded', function() {
    
    // --- CONFIGURATION ---
    const overlay = document.getElementById('mst-overlay');
    const ui = document.getElementById('mst-ui');
    const hintText = document.getElementById('mst-hint-text');
    
    // Liste des couleurs de la séquence (comme display-test.app)
    const sequence = ['#FFFFFF', '#000000', '#FF0000', '#00FF00', '#0000FF', '#FFFF00', '#00FFFF', '#FF00FF'];
    let currentIndex = 0;
    
    // --- FONCTIONS LOGIQUES ---

    function enterTestMode(startIndex = 0) {
        currentIndex = startIndex;
        
        // 1. Appliquer la couleur
        overlay.style.backgroundColor = sequence[currentIndex];
        overlay.style.display = 'block';

        // 2. Afficher l'aide temporairement
        ui.style.opacity = '1';
        setTimeout(() => { ui.style.opacity = '0'; }, 2500);

        // 3. Demander le plein écran (Cross-browser)
        const el = document.documentElement;
        if (el.requestFullscreen) el.requestFullscreen().catch(err => console.log(err));
        else if (el.webkitRequestFullscreen) el.webkitRequestFullscreen();
        else if (el.msRequestFullscreen) el.msRequestFullscreen();
    }

    function nextColor() {
        // Passe à la couleur suivante en boucle
        currentIndex = (currentIndex + 1) % sequence.length;
        overlay.style.backgroundColor = sequence[currentIndex];
        
        // Petit flash d'info pour dire quelle couleur c'est (optionnel, retiré pour immersion totale)
    }

    function exitTestMode() {
        overlay.style.display = 'none';
        if (document.exitFullscreen) document.exitFullscreen().catch(err => {});
        else if (document.webkitExitFullscreen) document.webkitExitFullscreen();
    }

    // --- ATTACHEMENT DES ÉVÉNEMENTS (C'est ici que ça répare votre bug) ---

    // 1. Le gros bouton START
    const mainBtn = document.getElementById('mst-start-main');
    if(mainBtn) {
        mainBtn.addEventListener('click', function() {
            enterTestMode(0); // Commence par Blanc
        });
    }

    // 2. Les boutons raccourcis (Shortcuts)
    const shortcuts = {
        'sc-white': 0,
        'sc-black': 1,
        'sc-red': 2,
        'sc-green': 3,
        'sc-blue': 4
    };

    for (const [id, index] of Object.entries(shortcuts)) {
        const btn = document.getElementById(id);
        if (btn) {
            btn.addEventListener('click', function() {
                enterTestMode(index);
            });
        }
    }

    // 3. Navigation dans l'overlay (Clic pour changer)
    overlay.addEventListener('click', nextColor);

    // 4. Gestion touche ESC (Redondance de sécurité)
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            exitTestMode();
        }
        // Flèche droite pour suivant
        if (e.key === 'ArrowRight' || e.key === ' ') {
            nextColor();
        }
        // Flèche gauche pour précédent
        if (e.key === 'ArrowLeft') {
            currentIndex = (currentIndex - 1 + sequence.length) % sequence.length;
            overlay.style.backgroundColor = sequence[currentIndex];
        }
    });
});</script><script>function smartPrint(url) {
    try {
        // Ouvre le PDF dans une fenêtre popup (800x600) pour l'impression
        var win = window.open(url, 'print_popup', 'toolbar=no,location=no,status=no,menubar=no,scrollbars=yes,resizable=yes,width=800,height=600');
        
        // Si le navigateur autorise le popup
        if (win) {
            win.onload = function() {
                // Attente de sécurité (1 seconde) pour que le PDF s'affiche avant d'imprimer
                setTimeout(function() {
                    win.focus();
                    win.print();
                }, 1000);
            };
            // "return false" dit au navigateur : "C'est bon, le JS a géré, n'ouvre pas le lien href"
            return false; 
        }
    } catch (e) { 
        console.log("Popup bloqué ou erreur JS, ouverture standard via href."); 
    }
    
    // Si on arrive ici, c'est que le JS a échoué.
    // "return true" dit au navigateur : "Ouvre le lien href normalement (nouvel onglet)"
    return true; 
}</script><link rel="icon" href="https://filesfortesting.com/wp-content/uploads/2026/01/icon-filesfortesting.png" sizes="32x32" />
