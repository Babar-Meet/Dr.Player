<style id="wp-custom-css">
/* --- 1. STRUCTURE PRINCIPALE --- */
.pd-wrapper {
    max-width: 1200px;
    margin: 40px auto;
    font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    color: #334155;
    padding: 0 15px; /* Marge de sécurité sur mobile */
}

/* --- 2. EN-TÊTE (HERO) --- */
.pd-header {
    text-align: center;
    margin-bottom: 50px;
    padding-bottom: 30px;
    border-bottom: 2px solid #f1f5f9;
}
.pd-header h2 {
    font-size: 2.2rem;
    color: #0f172a;
    font-weight: 800;
    margin-bottom: 15px;
    margin-top: 0;
}
.pd-header p {
    font-size: 1.1rem;
    color: #64748b;
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
}

/* --- 3. GRILLE DE CARTES (3 COLONNES) --- */
.pd-grid {
    display: grid;
    /* Force 3 colonnes de largeur égale sur PC */
    grid-template-columns: repeat(3, 1fr); 
    gap: 30px;
    align-items: stretch; /* Hauteur égale pour toutes les cartes */
    margin-bottom: 60px;
}

/* --- 4. STYLE DES CARTES --- */
.pd-card {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 35px 25px;
    text-align: center;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}
.pd-card:hover {
    transform: translateY(-7px);
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
    border-color: #cbd5e1;
}

/* --- 5. ÉLÉMENTS VISUELS --- */
.pd-icon { font-size: 3rem; margin-bottom: 20px; display: block; }
.pd-title { font-size: 1.4rem; font-weight: 700; margin: 0 0 15px 0; }
.pd-desc { 
    font-size: 0.95rem; 
    line-height: 1.6; 
    color: #64748b; 
    margin-bottom: 30px; 
}

/* --- 6. BOUTONS D'ACTION --- */
.pd-btn {
    display: block;
    width: 100%;
    padding: 16px;
    border-radius: 8px;
    text-decoration: none !important;
    font-weight: 700;
    color: #ffffff !important;
    font-size: 1rem;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}
.pd-btn:hover { opacity: 0.85; }

/* Couleurs Thématiques */
.pd-blue { color: #2563eb; }
.bg-blue { background-color: #2563eb; }

.pd-green { color: #059669; }
.bg-green { background-color: #059669; }

.pd-gray { color: #475569; }
.bg-gray { background-color: #475569; }

/* --- 7. SECTION CONTENU SEO & FAQ --- */
.pd-content {
    background: #f8fafc;
    border-radius: 16px;
    padding: 50px;
    border: 1px solid #e2e8f0;
}
.pd-section { margin-bottom: 40px; }
.pd-section:last-child { margin-bottom: 0; }

.pd-section h3 {
    font-size: 1.6rem;
    color: #0f172a;
    margin-bottom: 25px;
    font-weight: 700;
    margin-top: 0;
}
.pd-section p {
    font-size: 1rem;
    line-height: 1.7;
    color: #475569;
    margin-bottom: 15px;
}

/* Guides de diagnostic */
.pd-guides {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
}
.pd-guide-item h4 {
    font-size: 1.1rem;
    color: #1e293b;
    margin-bottom: 10px;
    font-weight: 700;
    display: flex;
    align-items: center;
}
.pd-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    color: white;
    font-size: 0.8rem;
    font-weight: bold;
    margin-right: 12px;
}

/* Diviseur */
.pd-divider {
    border: 0;
    height: 1px;
    background: #e2e8f0;
    margin: 40px 0;
}

/* FAQ List */
.pd-faq-list { list-style: none; padding: 0; margin: 0; }
.pd-faq-list li {
    margin-bottom: 25px;
    padding-left: 20px;
    border-left: 4px solid #cbd5e1;
}
.pd-faq-list strong {
    display: block;
    color: #0f172a;
    margin-bottom: 8px;
    font-size: 1.1rem;
}

/* --- 8. RESPONSIVE MOBILE --- */
@media (max-width: 900px) {
    .pd-grid { grid-template-columns: 1fr; } /* 1 colonne sur mobile */
    .pd-content { padding: 25px; }
    .pd-header h2 { font-size: 1.8rem; }
}
/******* SEPARATATION

/* --- 1. CONTAINER GLOBAL --- */
.mst-wrapper {
    max-width: 1000px;
    margin: 40px auto;
    font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    color: #334155;
    text-align: center;
    padding: 0 20px;
}

/* --- 2. EN-TÊTE --- */
.mst-header h2 {
    font-size: 2.5rem;
    color: #0f172a;
    margin-bottom: 10px;
    font-weight: 800;
    margin-top: 0;
}
.mst-header p {
    font-size: 1.1rem;
    color: #64748b;
    margin-bottom: 40px;
}

/* --- 3. GROS BOUTON START (Design Corrigé) --- */
.mst-start-btn {
    display: inline-flex; /* Assure le centrage parfait vertical/horizontal */
    justify-content: center;
    align-items: center;
    background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
    color: white;
    padding: 18px 45px;
    border-radius: 50px;
    font-size: 1.3rem;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 0 10px 25px -5px rgba(37, 99, 235, 0.4);
    transition: transform 0.2s, box-shadow 0.2s;
    border: none;
    margin-bottom: 50px;
    animation: pulse-blue 2s infinite; /* Animation d'appel à l'action */
    text-transform: uppercase;
    letter-spacing: 0.5px;
}
.mst-start-btn:hover {
    transform: scale(1.05);
    box-shadow: 0 20px 30px -10px rgba(37, 99, 235, 0.5);
}

@keyframes pulse-blue {
    0% { box-shadow: 0 0 0 0 rgba(59, 130, 246, 0.7); }
    70% { box-shadow: 0 0 0 15px rgba(59, 130, 246, 0); }
    100% { box-shadow: 0 0 0 0 rgba(59, 130, 246, 0); }
}

/* --- 4. ACCÈS RAPIDE (Puces Colorées) --- */
.mst-grid-title {
    margin-bottom: 20px;
    color: #94a3b8;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 1px;
    font-weight: 700;
}
.mst-grid {
    display: flex;
    justify-content: center;
    gap: 15px;
    flex-wrap: wrap;
    margin-bottom: 80px;
}
.mst-chip {
    padding: 12px 24px;
    border-radius: 12px;
    cursor: pointer;
    font-weight: 700;
    transition: all 0.2s;
    border: 1px solid rgba(0,0,0,0.1);
    box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    min-width: 80px;
}
.mst-chip:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 12px rgba(0,0,0,0.1);
}

/* Couleurs des boutons */
.chip-white { background: #ffffff; color: #334155; border-color: #cbd5e1; }
.chip-black { background: #000000; color: #ffffff; }
.chip-red   { background: #ef4444; color: #ffffff; }
.chip-green { background: #22c55e; color: #ffffff; }
.chip-blue  { background: #3b82f6; color: #ffffff; }

/* --- 5. OVERLAY (Écran de Test) --- */
#mst-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 2147483647; /* Au-dessus de tout */
    background-color: black;
    cursor: none; /* Cache la souris */
}

/* Instructions Flottantes */
#mst-ui {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    pointer-events: none;
    transition: opacity 0.5s;
    opacity: 0;
    width: 100%;
}
.mst-hint {
    display: inline-block;
    background: rgba(0,0,0,0.7);
    color: white;
    padding: 15px 30px;
    border-radius: 50px;
    font-size: 1.4rem;
    font-weight: 600;
    backdrop-filter: blur(5px);
    border: 1px solid rgba(255,255,255,0.2);
    margin-bottom: 15px;
}
.mst-sub-hint {
    color: rgba(255,255,255,0.9);
    font-size: 1.1rem;
    font-weight: 500;
    text-shadow: 0 2px 4px rgba(0,0,0,0.5);
}

/* --- 6. CONTENU SEO EXPERT (Article) --- */
.mst-article {
    text-align: left;
    max-width: 800px;
    margin: 0 auto;
    padding-bottom: 60px;
}
.mst-divider {
    border: 0;
    height: 1px;
    background: #e2e8f0;
    margin: 50px 0;
}
.mst-text-block { margin-bottom: 40px; }
.mst-text-block h3 {
    font-size: 1.6rem;
    color: #0f172a;
    margin-bottom: 15px;
    font-weight: 700;
}
.mst-text-block p {
    font-size: 1rem;
    line-height: 1.7;
    color: #475569;
    margin-bottom: 15px;
}

/* Listes */
.mst-list { margin-left: 20px; line-height: 1.8; color: #334155; }
.mst-list li { margin-bottom: 10px; }

/* Tableau ISO */
.mst-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 20px;
    background: white;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    border: 1px solid #e2e8f0;
}
.mst-table th, .mst-table td {
    padding: 15px;
    text-align: left;
    border-bottom: 1px solid #e2e8f0;
}
.mst-table th { background: #f8fafc; color: #0f172a; font-weight: 700; }
.mst-table tr:last-child td { border-bottom: none; }

/* FAQ */
.mst-faq-item {
    background: #ffffff;
    padding: 20px;
    border-radius: 12px;
    border: 1px solid #e2e8f0;
    margin-bottom: 15px;
}
.mst-faq-item strong {
    display: block;
    color: #2563eb;
    margin-bottom: 5px;
    font-size: 1.1rem;
}

/* Responsive */
@media (max-width: 600px) {
    .mst-header h2 { font-size: 2rem; }
    .mst-start-btn { width: 100%; box-sizing: border-box; }
    .mst-table { font-size: 0.85rem; }
}
/* SEPARATION 2 POUR AUDIO TEST

/* --- CONTAINER GLOBAL --- */
.act-wrapper {
    max-width: 800px;
    margin: 40px auto;
    font-family: 'Segoe UI', Roboto, sans-serif;
    color: #e2e8f0;
    background-color: #0f172a;
    padding: 40px;
    border-radius: 20px;
    box-shadow: 0 20px 50px -10px rgba(0, 0, 0, 0.5);
    text-align: center;
    border: 1px solid #1e293b;
}

/* --- EN-TÊTE --- */
.act-header h2 {
    font-size: 2.2rem;
    background: linear-gradient(to right, #38bdf8, #818cf8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 10px;
    font-weight: 800;
}

/* --- SCÈNE VISUELLE --- */
.act-stage {
    display: flex;
    justify-content: center;
    gap: 40px;
    margin: 40px 0;
}

/* Enceinte */
.act-speaker {
    width: 120px;
    height: 190px;
    background: #1e293b;
    border-radius: 12px;
    border: 4px solid #334155;
    position: relative;
    box-shadow: 0 10px 20px rgba(0,0,0,0.3);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    transition: transform 0.1s;
}

/* Tweeter & Woofer */
.act-tweeter { width: 35px; height: 35px; background: #0f172a; border-radius: 50%; border: 2px solid #475569; margin-bottom: 25px; }
.act-woofer { width: 75px; height: 75px; background: #0f172a; border-radius: 50%; border: 3px solid #475569; transition: transform 0.05s; }
.act-label { position: absolute; bottom: -30px; font-weight: bold; color: #64748b; font-size: 1.2rem; }

/* ANIMATION ACTIVE */
.playing { border-color: #38bdf8; transform: scale(1.05); box-shadow: 0 0 25px rgba(56, 189, 248, 0.4); }
.playing .act-woofer { animation: boom 0.2s infinite alternate; border-color: #38bdf8; background: #1e293b; }
@keyframes boom { 0% { transform: scale(1); } 100% { transform: scale(1.15); } }

/* --- CONTRÔLES --- */
.act-controls { display: flex; gap: 15px; justify-content: center; flex-wrap: wrap; margin-bottom: 40px; }
.act-btn {
    background: #1e293b; border: 1px solid #475569; color: #f1f5f9;
    padding: 15px 25px; border-radius: 10px; font-size: 1rem; font-weight: 700;
    cursor: pointer; display: flex; align-items: center; gap: 10px; transition: all 0.2s;
}
.act-btn:hover { background: #334155; transform: translateY(-3px); border-color: #94a3b8; }
.act-btn:active { transform: translateY(0); }

/* --- PHASE --- */
.act-phase { background: #1e293b; padding: 25px; border-radius: 15px; border: 1px solid #334155; text-align: left; }
.act-phase h3 { margin: 0 0 10px 0; color: white; }
.act-status { float: right; font-size: 0.8rem; background: #0f172a; padding: 5px 10px; border-radius: 20px; color: #64748b; }

/* --- STYLE CONTENU SEO --- */
.act-article { text-align: left; margin-top: 40px; padding: 0 10px; }
.act-divider { border: 0; height: 1px; background: #334155; margin: 40px 0; }
.act-text-block { margin-bottom: 40px; }
.act-text-block h3 { color: #f1f5f9; font-size: 1.5rem; margin-bottom: 15px; border-left: 4px solid #38bdf8; padding-left: 15px; }
.act-text-block p { color: #cbd5e1; line-height: 1.7; margin-bottom: 15px; }
.act-list { color: #cbd5e1; line-height: 1.8; margin-left: 20px; }
.act-list strong { color: #38bdf8; }
.act-alert { background: rgba(56, 189, 248, 0.1); border: 1px solid #38bdf8; padding: 20px; border-radius: 10px; color: #e0f2fe; margin-top: 15px; }

/* Tableau Dark Mode */
.act-table { width: 100%; border-collapse: collapse; margin-top: 20px; background: #1e293b; border-radius: 8px; overflow: hidden; }
.act-table th, .act-table td { padding: 15px; text-align: left; border-bottom: 1px solid #334155; color: #cbd5e1; }
.act-table th { background: #0f172a; color: #38bdf8; font-weight: bold; text-transform: uppercase; font-size: 0.85rem; }
.act-table tr:last-child td { border-bottom: none; }

@media (max-width: 600px) {
    .act-stage { gap: 20px; }
    .act-speaker { width: 100px; height: 160px; }
    .act-table { font-size: 0.9rem; }
}
/* SEPARATEUR POUR BARRE CODE

/* --- CONTAINER PRINCIPAL --- */
.bct-wrapper {
    max-width: 1100px;
    margin: 40px auto;
    font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    color: #334155;
    padding: 20px;
}

/* --- HEADER --- */
.bct-header {
    text-align: center;
    margin-bottom: 50px;
    padding-bottom: 30px;
    border-bottom: 2px solid #f1f5f9;
}
.bct-header h2 {
    font-size: 2.2rem;
    color: #0f172a;
    font-weight: 800;
    margin-bottom: 10px;
    margin-top: 0;
}
.bct-header p {
    font-size: 1.1rem;
    color: #64748b;
    max-width: 700px;
    margin: 0 auto;
}

/* --- GRILLE DES OUTILS --- */
.bct-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 30px;
    margin-bottom: 60px;
}

/* --- CARTES --- */
.bct-card {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 30px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.bct-card:hover {
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
    border-color: #cbd5e1;
}
.bct-card h3 {
    margin-top: 0;
    color: #0f172a;
    font-size: 1.4rem;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
}

/* --- FORMULAIRES --- */
.bct-form-group {
    margin-bottom: 20px;
}
.bct-label {
    display: block;
    font-weight: 600;
    margin-bottom: 8px;
    color: #475569;
    font-size: 0.95rem;
}
.bct-input, .bct-select {
    width: 100%;
    padding: 12px;
    border: 2px solid #e2e8f0;
    border-radius: 8px;
    font-size: 1rem;
    transition: border-color 0.2s;
    box-sizing: border-box; /* Important pour que le padding ne dépasse pas */
}
.bct-input:focus, .bct-select:focus {
    border-color: #3b82f6;
    outline: none;
}
.bct-helper {
    font-size: 0.85rem;
    color: #94a3b8;
    margin-top: 6px;
}

/* --- ZONE DE RÉSULTAT (CODE-BARRES) --- */
.bct-result-container {
    margin-top: 30px;
    padding: 20px;
    background: #f8fafc;
    border-radius: 12px;
    border: 2px dashed #cbd5e1;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 200px; /* Hauteur minimale pour éviter les sauts */
    background-color: white;
}

/* Styles spécifiques pour que les SVG soient beaux */
.bct-result-container svg {
    max-width: 100%;
    height: auto;
    display: block;
    /* Ombre légère pour faire ressortir le code */
    filter: drop-shadow(0px 4px 6px rgba(0,0,0,0.05));
}
/* Pour le QR code WiFi */
#wifi-qr-output svg {
     max-height: 250px;
}


/* --- SECTION SEO --- */
.bct-content {
    background: #f8fafc;
    border-radius: 16px;
    padding: 40px;
    border: 1px solid #e2e8f0;
}
.bct-section h3 {
    font-size: 1.6rem;
    color: #0f172a;
    margin-bottom: 20px;
    font-weight: 700;
    margin-top: 0;
}
.bct-section p {
    font-size: 1rem;
    line-height: 1.7;
    color: #475569;
    margin-bottom: 15px;
}
.bct-list { margin-left: 20px; line-height: 1.8; }
.bct-list li { margin-bottom: 10px; }

@media (max-width: 768px) {
    .bct-grid { grid-template-columns: 1fr; }
    .bct-header h2 { font-size: 1.8rem; }
}

/* separation pour page hardware

/* --- CONFIGURATION GLOBALE --- */
.hub-wrapper {
    max-width: 1200px;
    margin: 40px auto;
    font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    color: #e2e8f0;
    background-color: #0f172a;
    padding: 60px 20px;
    border-radius: 20px;
    box-shadow: 0 20px 50px -10px rgba(0, 0, 0, 0.5);
    text-align: center;
}

/* --- EN-TÊTE --- */
.hub-header { margin-bottom: 60px; }
.hub-header h1 {
    font-size: 2.8rem;
    font-weight: 800;
    margin: 0 0 15px 0;
    background: linear-gradient(to right, #38bdf8, #818cf8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}
.hub-header p {
    font-size: 1.2rem;
    color: #94a3b8;
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
}

/* --- GRILLE --- */
.hub-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
    padding: 0 10px;
}

/* --- CARTES --- */
.hub-card {
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 16px;
    padding: 30px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    overflow: hidden;
    height: 100%;
}
.hub-card:hover {
    transform: translateY(-7px);
    box-shadow: 0 15px 30px -5px rgba(0, 0, 0, 0.3);
    border-color: #38bdf8;
}

.hub-icon {
    font-size: 3rem;
    margin-bottom: 20px;
    background: #0f172a;
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 2px solid #475569;
    box-shadow: inset 0 2px 5px rgba(0,0,0,0.5);
}

.hub-card h3 { color: #fff; font-size: 1.4rem; margin: 0 0 10px 0; font-weight: 700; }
.hub-card p { color: #94a3b8; font-size: 0.95rem; margin-bottom: 25px; line-height: 1.5; flex-grow: 1; }

.hub-btn {
    text-decoration: none;
    background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
    color: white !important;
    padding: 12px 30px;
    border-radius: 50px;
    font-weight: 700;
    font-size: 1rem;
    transition: all 0.2s;
    box-shadow: 0 4px 15px rgba(37, 99, 235, 0.4);
    display: inline-block;
}
.hub-btn:hover { transform: scale(1.05); color: white; }

.hub-badge {
    position: absolute; top: 15px; right: 15px; background: #064e3b; color: #34d399;
    font-size: 0.7rem; padding: 4px 10px; border-radius: 20px;
    text-transform: uppercase; font-weight: bold; letter-spacing: 0.5px; border: 1px solid #059669;
}

/* --- NOUVEAU : STYLE CONTENU SEO --- */
.hub-article {
    text-align: left;
    margin-top: 80px;
    padding: 0 20px;
    color: #cbd5e1;
}
.hub-divider {
    border: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, #334155, transparent);
    margin: 60px 0;
}
.hub-text-block h2 {
    color: #f1f5f9;
    font-size: 2rem;
    margin-bottom: 20px;
    text-align: center;
}
.hub-text-block p {
    line-height: 1.8;
    font-size: 1.05rem;
    margin-bottom: 30px;
    text-align: center;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
}

/* Feature Grid pour le texte */
.hub-features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 40px;
    margin: 50px 0;
}
.hub-feature-item h3 {
    color: #38bdf8;
    font-size: 1.3rem;
    margin-bottom: 15px;
    font-weight: 700;
}
.hub-feature-item p {
    color: #94a3b8;
    line-height: 1.7;
    font-size: 0.95rem;
    margin: 0;
}

/* FAQ Style */
.hub-faq {
    background: #1e293b;
    padding: 25px;
    border-radius: 12px;
    margin-bottom: 20px;
    border: 1px solid #334155;
}
.hub-faq strong {
    display: block;
    color: #f1f5f9;
    font-size: 1.1rem;
    margin-bottom: 10px;
}
.hub-faq p {
    text-align: left; /* Force alignement gauche pour la FAQ */
    margin: 0;
    font-size: 0.95rem;
}

@media (max-width: 768px) {
    .hub-header h1 { font-size: 2rem; }
    .hub-grid { grid-template-columns: 1fr; }
    .hub-text-block h2 { font-size: 1.5rem; }
}

/* SEPARATION MASQUER DESCRIPTION EN HAUT

/* Essaie de cacher toutes les variantes possibles de résumés automatiques */
.page-template-default .entry-header,
.page-template-default .entry-summary,
.page-template-default .page-header p,
header.entry-header p {
    display: none !important;
}

/* LOREM IPSUM

/* --- CONTAINER GLOBAL --- */
.lipsum-wrapper {
    max-width: 900px;
    margin: 40px auto;
    font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    color: #e2e8f0;
    background-color: #0f172a;
    padding: 40px;
    border-radius: 20px;
    box-shadow: 0 20px 50px -10px rgba(0, 0, 0, 0.5);
}

/* --- EN-TÊTE --- */
.lipsum-header { text-align: center; margin-bottom: 40px; }
.lipsum-header h1 {
    font-size: 2.5rem; margin: 0 0 10px 0;
    background: linear-gradient(to right, #38bdf8, #818cf8);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
}
.lipsum-header p { color: #94a3b8; font-size: 1.1rem; }

/* --- CONTRÔLES --- */
.lipsum-controls {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    background: #1e293b;
    padding: 25px;
    border-radius: 12px;
    border: 1px solid #334155;
    margin-bottom: 30px;
    align-items: end;
}

.control-group label {
    display: block; color: #cbd5e1; font-size: 0.9rem; margin-bottom: 8px; font-weight: 600;
}

/* INPUTS & SELECTS */
input[type="number"], select {
    width: 100%; padding: 10px 15px; background: #0f172a; border: 1px solid #475569;
    color: white; border-radius: 8px; font-size: 1rem; outline: none;
}
input[type="number"]:focus, select:focus { border-color: #38bdf8; }

/* TOGGLE BUTTONS */
.toggle-switch { display: flex; background: #0f172a; border-radius: 8px; overflow: hidden; border: 1px solid #475569; }
.toggle-btn {
    flex: 1; border: none; background: transparent; color: #94a3b8;
    padding: 10px; cursor: pointer; font-size: 0.9rem; transition: 0.2s;
}
.toggle-btn.active { background: #3b82f6; color: white; font-weight: bold; }

/* CHECKBOX */
.checkbox-group { display: flex; align-items: center; padding-bottom: 10px; }
.checkbox-group input { margin-right: 10px; transform: scale(1.2); }
.checkbox-group label { margin: 0; cursor: pointer; }

/* --- ACTIONS --- */
.lipsum-actions { text-align: center; margin-bottom: 30px; }
.action-btn {
    background: linear-gradient(135deg, #10b981 0%, #059669 100%);
    color: white; padding: 15px 40px; border: none; border-radius: 50px;
    font-size: 1.1rem; font-weight: bold; cursor: pointer; transition: transform 0.2s;
    box-shadow: 0 4px 15px rgba(16, 185, 129, 0.4);
}
.action-btn:hover { transform: translateY(-2px); }
.action-btn:active { transform: translateY(1px); }

/* --- OUTPUT --- */
.lipsum-output-container {
    background: #1e293b; border-radius: 12px; border: 1px solid #334155; overflow: hidden;
}
.output-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 10px 20px; background: #0f172a; border-bottom: 1px solid #334155;
}
.output-label { color: #94a3b8; font-size: 0.85rem; font-weight: bold; text-transform: uppercase; }

.copy-btn {
    background: #334155; color: white; border: none; padding: 5px 15px;
    border-radius: 4px; cursor: pointer; font-size: 0.85rem; transition: 0.2s;
}
.copy-btn:hover { background: #475569; }

textarea#lorem-result {
    width: 100%; height: 300px; background: #1e293b; color: #cbd5e1;
    border: none; padding: 20px; font-family: 'Courier New', monospace;
    font-size: 1rem; line-height: 1.6; resize: vertical; outline: none;
}
/* --- FIX : Force la couleur sombre quand on clique dans la case --- */
.lipsum-controls input[type="number"]:focus,
.lipsum-controls select:focus {
    background-color: #0f172a !important; /* Garde le fond sombre */
    color: #ffffff !important;           /* Force le texte en blanc */
    border-color: #38bdf8 !important;    /* Bordure bleue */
    outline: none !important;
    box-shadow: none !important;         /* Enlève l'ombre blanche par défaut */
}
/* --- NOUVEAU : STYLE CONTENU SEO --- */
.lipsum-seo-content {
    text-align: left;
    margin-top: 60px;
    padding: 0 10px;
    color: #cbd5e1;
}

.lipsum-divider {
    border: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, #334155, transparent);
    margin: 50px 0;
}

.lipsum-text-block { margin-bottom: 40px; }

.lipsum-text-block h2 {
    color: #f1f5f9; font-size: 1.8rem; margin-bottom: 15px; font-weight: 700;
}
.lipsum-text-block h3 {
    color: #38bdf8; font-size: 1.4rem; margin-bottom: 15px;
}
.lipsum-text-block p {
    line-height: 1.7; font-size: 1rem; margin-bottom: 20px; color: #94a3b8;
}

/* LISTE A PUCES */
.lipsum-list { list-style: none; padding: 0; }
.lipsum-list li {
    margin-bottom: 15px; padding-left: 20px; position: relative; color: #cbd5e1;
}
.lipsum-list li::before {
    content: "•"; color: #38bdf8; font-weight: bold; font-size: 1.2rem;
    position: absolute; left: 0; top: -2px;
}
.lipsum-list strong { color: #f1f5f9; }

/* FAQ */
.lipsum-faq {
    background: #1e293b; padding: 20px; border-radius: 8px;
    margin-bottom: 15px; border-left: 3px solid #3b82f6;
}
.lipsum-faq strong {
    display: block; color: #fff; font-size: 1.05rem; margin-bottom: 5px;
}
.lipsum-faq p { margin: 0; font-size: 0.95rem; }

/* Code tags dans le texte */
code {
    background: #0f172a; padding: 2px 6px; border-radius: 4px;
    color: #f472b6; font-family: monospace; font-size: 0.9em;
}
</style>
</head>

